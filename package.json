{
  "name": "tonal",
  "version": "5.0.0",
  "type": "module",
  "description": "Two-way tone translator Chrome Extension",
  "main": "background.js",
  "scripts": {
    "deploy": "cd backend && wrangler deploy",
    "dev": "cd backend && wrangler dev",
    "zip": "powershell -Command \"Compress-Archive -Path extension/* -DestinationPath website/public/tonal-extension.zip -Force\"",
    "test": "node --test tests/worker.test.js tests/worker_logic.test.js tests/worker_real_scenarios.test.js",
    "kill": "npx kill-port 3000 3001 3002 8080",
    "save": "git add -A && git commit -m \"checkpoint: [timestamp]\" && git push"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
